#!/usr/bin/env bash
#
# tmt (tmux-tasks) — monitor & interact with per-task tmux sessions from one place.
#
# You run each task in its own tmux session. This tool lists them, detects
# whether each is running / idle / waiting-for-input, shows a live table, and
# lets you send input to a session without attaching. It also has an
# `agent-scan` subcommand that emits a compact digest a coding agent can read
# to interpret status and decide what input to send.
#
# Subcommands:
#   watch [--filter GLOB] [--interval N]   Live table + single-key actions (default)
#   ls    [--filter GLOB]                   One-shot table, then exit
#   status SESSION                          Detailed view of one session
#   capture SESSION [--lines N]             Dump a session's pane (for humans/agents)
#   send  SESSION -- TEXT...                Send a line of input to a session
#   ask   SESSION [--timeout S] [--quiescent S] [--lines N] -- PROMPT
#                                           Send prompt, await reply (JSON output)
#   key   SESSION KEY...                    Send raw tmux keys (e.g. Enter, C-c, y)
#   new   NAME [-- CMD...]                   Create a task session (optionally run CMD)
#   dispatch NAME --type T [--isolation worktree|cwd] [--repo D] [--branch B]
#            [--cwd D] -- "CMD"              Create one isolated giant task + register it
#   registry [SESSION]                       Show session metadata (JSON)
#   save  [--filter GLOB] [--name NAME]     Snapshot session layout+cwd+cmd to disk
#   restore [SNAPSHOT] [--run] [--dry-run]  Recreate sessions from a snapshot
#   snapshots                               List saved snapshots
#   agent-scan [--filter GLOB] [--json]     Digest of all sessions for an agent
#   serve [--filter GLOB] [--interval N] [--port P] [--lines N]
#                                           Live HTML dashboard (localhost, auto-refresh)
#   attach SESSION                          Attach to a session (exits monitor)
#   version                                 Print version
#
# Reboot safety: a reboot kills every process, so no tool can revive a running
# build or a live agent. `tmt save` snapshots the session *layout* (name, cwd,
# and the foreground command). After reboot, `tmt restore --run` recreates the
# sessions and re-launches those commands. Snapshots live in
# ~/.local/share/tmux-tasks/ (persistent, not /tmp).
#
# State detection (mixed CLI tools):
#   RUNNING  a non-shell process is foreground and output is moving
#   WAITING  last line looks like an interactive prompt (y/n, password, ?, :)
#   IDLE     foreground process is a shell (nothing running)
#   STALE    non-shell process but output unchanged since last scan (maybe hung)

set -uo pipefail

TMT_VERSION="0.4.0"

# Stable exit codes (see DESIGN.md §5) so a program consumer can branch on them.
EX_OK=0; EX_USAGE=2; EX_NOSESSION=3; EX_LOCKED=4; EX_POLICY=5; EX_NOTMUX=6; EX_TIMEOUT=7

# Data root. Everything persistent lives here (NOT /tmp, which reboots wipe).
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tmux-tasks"

# Ephemeral scan state (pane hashes for RUNNING vs STALE). OK to lose on reboot.
STATE_DIR="${TMPDIR:-/tmp}/tmux-tasks-${USER:-$(id -un)}"
mkdir -p "$STATE_DIR"

# Persistent snapshots for save/restore.
SNAP_DIR="$DATA_DIR/snapshots"
mkdir -p "$SNAP_DIR"
SNAP_KEEP=20   # how many timestamped snapshots to retain

# Persistent per-session metadata (type, task, isolation, ready-pattern, ...).
REG_DIR="$DATA_DIR/registry"
mkdir -p "$REG_DIR"

SHELLS='^(bash|zsh|sh|fish|dash|tcsh|ksh|-bash|-zsh)$'

# Prompt patterns that indicate a program is blocked waiting for the user.
PROMPT_RE='(\?[[:space:]]*$|\((y|Y)(es)?/(n|N)(o)?\)|\[[yYnN]/[yYnN]\]|[Pp]assword.*:|[Pp]assphrase.*:|[Cc]ontinue\??|[Pp]roceed|[Oo]verwrite|\[y/N\]|\[Y/n\]|press[[:space:]]+enter|:[[:space:]]*$|❯[[:space:]]*$|»[[:space:]]*$)'

# Ready-box pattern: the agent's empty input prompt (turn completed).
# Separate from PROMPT_RE (which detects questions like y/n). Matches:
#   ❯  (Claude Code), >  (aider), $  (shell)
READY_RE='(❯[[:space:]]*$|^>[[:space:]]*$|\$[[:space:]]*$)'

# --- per-session lock (mkdir-based, atomic, no flock dependency) --------------
#
# Serializes tmt-initiated input into one session so ask/send can't interleave.
# The lock dir lives in STATE_DIR (tmpfs): a reboot clears locks automatically.
# A lock whose recorded pid is dead is stale and gets stolen.

_lock_path() { printf '%s/%s.lock' "$STATE_DIR" "$(key_of "$1")"; }

# _lock_acquire SESSION [PID]  — PID defaults to $$; callers pass a longer-lived
# pid when the logical holder outlives this process.
_lock_acquire() {
  local sess="$1" pid="${2:-$$}" lpath
  lpath=$(_lock_path "$sess")
  if mkdir "$lpath" 2>/dev/null; then
    printf '%s' "$pid" > "$lpath/pid" || { rm -rf "$lpath"; die "$EX_LOCKED" "cannot write lock pid"; }
    return 0
  fi
  # Require a well-formed positive pid before the liveness probe: kill -0 on
  # 0/-1 "succeeds" and would make a corrupted lock permanent.
  # kill -0 EPERM edge: STATE_DIR is per-user, so an unsignalable pid means the
  # pid was recycled by another user's process — the real holder is dead.
  local holder
  holder=$(cat "$lpath/pid" 2>/dev/null || true)
  if [[ "$holder" =~ ^[0-9]+$ ]] && kill -0 "$holder" 2>/dev/null; then
    die "$EX_LOCKED" "session $sess is locked by pid $holder"
  fi
  # Holder dead or unreadable — steal via atomic rename so two concurrent
  # stealers can't both win: only one mv succeeds, and the loser must not
  # rm the winner's fresh lock.
  mv "$lpath" "$lpath.stale.$$" 2>/dev/null \
    || die "$EX_LOCKED" "session $sess is locked (lost steal race)"
  rm -rf "$lpath.stale.$$"
  if mkdir "$lpath" 2>/dev/null; then
    printf '%s' "$pid" > "$lpath/pid" || { rm -rf "$lpath"; die "$EX_LOCKED" "cannot write lock pid"; }
    return 0
  fi
  die "$EX_LOCKED" "session $sess is locked (lost steal race)"
}

_lock_release() { rm -rf "$(_lock_path "$1")"; }

# --- readiness detection (Phase B) -------------------------------------------
#
# _turn_done SESSION QUIESCENT_SECS
#   Checks if the session's pane has been stable for QUIESCENT seconds AND the
#   tail matches a pattern indicating the agent finished. Prints one of:
#     "done"    — ready box showing (READY_RE), agent finished its turn
#     "blocked" — question prompt showing (PROMPT_RE minus the ready-box overlap)
#     "active"  — pane still changing or hasn't been quiescent long enough
#
# Meant to be POLLED (once/sec by ask). The state file records two lines:
# the pane hash and the epoch second that hash was first observed. The first
# call after any change (including the very first call ever) resets the timer
# and reports "active"; subsequent calls accumulate elapsed quiescent time.
#
# READY_RE is checked BEFORE PROMPT_RE: a bare `❯ ` matches both (PROMPT_RE
# includes it as an alternative), but it is a ready box — the agent finished —
# not a blocking question. PROMPT_RE only classifies "blocked" via its more
# specific patterns (y/n, password:, continue?, ...).
#
# Uses .ask.hash (not .hash) so it never perturbs detect()'s RUNNING/STALE state.

_turn_done() {
  local sess="$1" quiescent="${2:-5}"
  local pane last hash statef prev prev_time now elapsed

  pane=$(tmux capture-pane -t "$sess" -p 2>/dev/null)
  last=$(printf '%s\n' "$pane" | grep -v '^[[:space:]]*$' | tail -n 1)
  hash=$(printf '%s' "$pane" | cksum | cut -d' ' -f1)

  statef="$STATE_DIR/$(key_of "$sess").ask.hash"
  now=$(date +%s)

  if [[ -f "$statef" ]]; then
    prev=$(sed -n '1p' "$statef")
    prev_time=$(sed -n '2p' "$statef")
  else
    prev=""; prev_time="$now"
  fi

  if [[ "$hash" != "$prev" ]]; then
    # Pane changed — reset the quiescence timer.
    printf '%s\n%s\n' "$hash" "$now" > "$statef"
    printf 'active'
    return
  fi

  # Pane unchanged — check how long.
  elapsed=$((now - prev_time))
  if [[ "$elapsed" -lt "$quiescent" ]]; then
    printf 'active'
    return
  fi

  # Quiescent long enough. Check what's showing.
  # READY_RE first: a bare ❯ is a ready box, not a question.
  if [[ "$last" =~ $READY_RE ]]; then
    printf 'done'
  elif [[ "$last" =~ $PROMPT_RE ]]; then
    printf 'blocked'
  else
    printf 'active'
  fi
}

# Colors only when stdout is a real terminal, so a program consuming our output
# (the orchestrator) never has to strip ANSI. NO_COLOR=1 also disables them.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  c_reset=$'\033[0m'; c_dim=$'\033[2m'; c_bold=$'\033[1m'
  c_red=$'\033[31m'; c_grn=$'\033[32m'; c_yel=$'\033[33m'; c_blu=$'\033[34m'; c_cyn=$'\033[36m'
else
  c_reset=''; c_dim=''; c_bold=''; c_red=''; c_grn=''; c_yel=''; c_blu=''; c_cyn=''
fi

# die [CODE] MESSAGE...  — default code EX_USAGE.
die() {
  local code=$EX_USAGE
  [[ "${1:-}" =~ ^[0-9]+$ ]] && { code="$1"; shift; }
  printf '%s\n' "$*" >&2; exit "$code"
}
need() { command -v "$1" &>/dev/null || die "required command not found: $1"; }
have_tmux() { need tmux; tmux info &>/dev/null || die "$EX_NOTMUX" "no tmux server running (start a session first)"; }

# List session names, optionally filtered by a glob against the name.
list_sessions() {
  local filter="${1:-*}"
  tmux list-sessions -F '#{session_name}' 2>/dev/null | while IFS= read -r s; do
    # shellcheck disable=SC2053
    [[ "$s" == $filter ]] && printf '%s\n' "$s"
  done
}

# Sanitize a session name into a filename-safe key.
key_of() { printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'; }

# Detect state for a session. Echoes: "STATE<TAB>CMD<TAB>LASTLINE"
detect() {
  local sess="$1"
  local cmd pane last hash prev statef
  cmd=$(tmux display-message -t "$sess" -p '#{pane_current_command}' 2>/dev/null)
  pane=$(tmux capture-pane -t "$sess" -p 2>/dev/null)
  last=$(printf '%s\n' "$pane" | grep -v '^[[:space:]]*$' | tail -n 1)
  hash=$(printf '%s' "$pane" | cksum | cut -d' ' -f1)

  statef="$STATE_DIR/$(key_of "$sess").hash"
  prev=""; [[ -f "$statef" ]] && prev=$(<"$statef")
  printf '%s' "$hash" > "$statef"

  local state
  if [[ "$last" =~ $PROMPT_RE ]]; then
    state="WAITING"
  elif [[ "$cmd" =~ $SHELLS ]]; then
    state="IDLE"
  elif [[ -n "$prev" && "$prev" == "$hash" ]]; then
    state="STALE"
  else
    state="RUNNING"
  fi
  printf '%s\t%s\t%s\n' "$state" "$cmd" "$last"
}

state_color() {
  case "$1" in
    RUNNING) printf '%s' "$c_grn" ;;
    WAITING) printf '%s' "$c_yel" ;;
    STALE)   printf '%s' "$c_red" ;;
    IDLE)    printf '%s' "$c_dim" ;;
    *)       printf '%s' "$c_reset" ;;
  esac
}

state_icon() {
  case "$1" in
    RUNNING) printf '▶' ;;
    WAITING) printf '⏳' ;;
    STALE)   printf '■' ;;
    IDLE)    printf '·' ;;
    *)       printf '?' ;;
  esac
}

# Print the table. Populates global arrays SESS[] and STATE[] for interactive use.
declare -a SESS STATE
render_table() {
  local filter="${1:-*}"
  SESS=(); STATE=()
  local i=0 sess line st rest cmd last
  printf '%s%-3s %-2s %-9s %-26s %s%s\n' "$c_bold" "#" "" "STATE" "SESSION" "LAST LINE" "$c_reset"
  while IFS= read -r sess; do
    [[ -z "$sess" ]] && continue
    line=$(detect "$sess")
    st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}; last=${rest#*$'\t'}
    SESS[i]="$sess"; STATE[i]="$st"
    last=${last:0:60}
    printf '%s%-3s %s%-2s %-9s%s %-26s %s%s%s\n' \
      "$c_dim" "$i" "$(state_color "$st")" "$(state_icon "$st")" "$st" "$c_reset" \
      "${sess:0:26}" "$c_dim" "$last" "$c_reset"
    i=$((i+1))
  done < <(list_sessions "$filter")
  [[ $i -eq 0 ]] && printf '%s(no sessions match)%s\n' "$c_dim" "$c_reset"
  return 0
}

cmd_ls() {
  have_tmux
  local filter='*'
  [[ "${1:-}" == "--filter" ]] && { filter="$2"; }
  render_table "$filter"
}

cmd_status() {
  have_tmux
  local sess="${1:?usage: tmt status SESSION}"
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"
  local line st rest cmd last
  line=$(detect "$sess")
  st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}; last=${rest#*$'\t'}
  printf '%sSession:%s %s\n' "$c_bold" "$c_reset" "$sess"
  printf '%sState:  %s %s%s%s  (fg process: %s)\n' "$c_bold" "$c_reset" "$(state_color "$st")" "$st" "$c_reset" "$cmd"
  printf '%s--- last 25 lines %s\n' "$c_dim" "$c_reset"
  tmux capture-pane -t "$sess" -p -S -25 2>/dev/null
}

cmd_capture() {
  have_tmux
  local sess="${1:?usage: tmt capture SESSION [--lines N]}"; shift
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"
  local lines=100
  [[ "${1:-}" == "--lines" ]] && lines="$2"
  tmux capture-pane -t "$sess" -p -S "-$lines" 2>/dev/null
}

# Type a line into a session and submit it. Sends the TEXT and the Enter as
# TWO separate send-keys calls with a short settle delay between them.
#
# Why not one call: TUI apps (Claude Code, aider, ...) ingest a paste
# char-by-char or via bracketed-paste. When text + Enter arrive in one burst,
# the Enter is absorbed into the input box (as a literal newline, or before the
# app finishes reading the paste) instead of submitting. Splitting them — and
# waiting for the app to settle — makes the submit reliable. Plain shells are
# unaffected either way. Delay overridable via TMT_SEND_DELAY (seconds).
_send_line() {
  local sess="$1" text="$2"
  local delay="${TMT_SEND_DELAY:-0.3}"
  tmux send-keys -t "$sess" -- "$text" || return 1
  # Let the target ingest the text before we submit.
  sleep "$delay"
  tmux send-keys -t "$sess" Enter
}

cmd_send() {
  have_tmux
  local sess="${1:?usage: tmt send SESSION -- TEXT}"; shift
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"
  [[ "${1:-}" == "--" ]] && shift
  local text="$*"
  _lock_acquire "$sess"
  # RETURN traps are global in bash: clear it as it fires so it doesn't fire
  # again when main() returns (where $sess is out of scope).
  trap '_lock_release "$sess"; trap - RETURN' RETURN
  _send_line "$sess" "$text" && \
    printf '%s→ sent to %s:%s %s\n' "$c_grn" "$sess" "$c_reset" "$text"
}

cmd_key() {
  have_tmux
  local sess="${1:?usage: tmt key SESSION KEY...}"; shift
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"
  _lock_acquire "$sess"
  trap '_lock_release "$sess"; trap - RETURN' RETURN
  tmux send-keys -t "$sess" "$@" && \
    printf '%s→ sent keys to %s:%s %s\n' "$c_grn" "$sess" "$c_reset" "$*"
}

cmd_new() {
  need tmux
  local name="${1:?usage: tmt new NAME [-- CMD...]}"; shift
  if tmux has-session -t "$name" 2>/dev/null; then
    die "session already exists: $name"
  fi
  tmux new-session -d -s "$name" || die "failed to create session: $name"
  if [[ "${1:-}" == "--" ]]; then
    shift
    _send_line "$name" "$*"
  fi
  printf '%s✓ created session%s %s\n' "$c_grn" "$c_reset" "$name"
}

cmd_attach() {
  have_tmux
  local sess="${1:?usage: tmt attach SESSION}"
  exec tmux attach -t "$sess"
}

# --- session registry -----------------------------------------------------
#
# Per-session metadata as JSON at $REG_DIR/<key>.json. Lets the orchestrator
# know WHAT each session is (type, task, isolation, ready-pattern) rather than
# only shell-vs-nonshell. Written by dispatch/new; read by agent-scan/registry.

reg_file() { printf '%s/%s.json' "$REG_DIR" "$(key_of "$1")"; }

# reg_write SESSION TYPE TASK ISOLATION LOCATION BRANCH READY
reg_write() {
  need jq
  local sess="$1" type="$2" task="$3" iso="$4" loc="$5" branch="$6" ready="$7"
  jq -n --arg s "$sess" --arg ty "$type" --arg ta "$task" --arg is "$iso" \
        --arg lo "$loc" --arg br "$branch" --arg re "$ready" \
    '{session:$s, type:$ty, task:$ta, isolation:$is, location:$lo, branch:$br, ready_pattern:$re}' \
    > "$(reg_file "$sess")"
}

# Echo a registry field, or empty if unregistered.
reg_get() {
  local f; f=$(reg_file "$1"); [[ -f "$f" ]] || return 0
  jq -r ".${2} // \"\"" "$f" 2>/dev/null
}

cmd_registry() {
  need jq
  local sess="${1:-}"
  if [[ -n "$sess" ]]; then
    local f; f=$(reg_file "$sess")
    [[ -f "$f" ]] || die "$EX_NOSESSION" "no registry entry for: $sess"
    cat "$f"; return
  fi
  # all entries as a JSON array
  local first=1; printf '['
  local f
  for f in "$REG_DIR"/*.json; do
    [[ -e "$f" ]] || continue
    [[ $first -eq 0 ]] && printf ','
    first=0; cat "$f"
  done
  printf ']\n'
}

# --- dispatch: create one isolated giant task -----------------------------
#
# tmt dispatch NAME --type TYPE [--isolation worktree|cwd] [--repo DIR]
#              [--branch B] [--cwd DIR] -- "opening prompt / command"
#
# isolation=worktree : git worktree add <repo>/../<branch> -b <branch>; cwd=there
# isolation=cwd      : run in --cwd (independent project); no worktree created
cmd_dispatch() {
  need tmux
  local name="${1:?usage: tmt dispatch NAME --type TYPE [opts] -- CMD}"; shift
  local type="shell" iso="cwd" repo="" branch="" cwd="" opening=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)      type="$2"; shift 2 ;;
      --isolation) iso="$2"; shift 2 ;;
      --repo)      repo="$2"; shift 2 ;;
      --branch)    branch="$2"; shift 2 ;;
      --cwd)       cwd="$2"; shift 2 ;;
      --)          shift; opening="$*"; break ;;
      *) die "dispatch: unknown option: $1" ;;
    esac
  done

  tmux has-session -t "$name" 2>/dev/null && die "session already exists: $name"

  local location=""
  case "$iso" in
    worktree)
      need git
      [[ -n "$repo" ]] || die "dispatch --isolation worktree requires --repo DIR"
      [[ -d "$repo/.git" || -f "$repo/.git" ]] || die "not a git repo: $repo"
      [[ -n "$branch" ]] || branch=$(key_of "$name")
      # place the worktree in a sibling dir of the repo: <repo>/../tmt-worktrees/<branch>
      local repo_abs; repo_abs=$(cd "$repo" && pwd)
      location="$(cd "$repo_abs/.." && pwd)/tmt-worktrees/$branch"
      if [[ ! -d "$location" ]]; then
        mkdir -p "$(dirname "$location")"
        git -C "$repo_abs" worktree add -b "$branch" "$location" 2>/dev/null \
          || git -C "$repo_abs" worktree add "$location" "$branch" 2>/dev/null \
          || die "git worktree add failed for branch $branch"
      fi
      ;;
    cwd)
      location="${cwd:-$PWD}"
      [[ -d "$location" ]] || die "dispatch --cwd not a directory: $location"
      ;;
    *) die "dispatch --isolation must be 'worktree' or 'cwd' (got: $iso)" ;;
  esac

  tmux new-session -d -s "$name" -c "$location" || die "failed to create session: $name"

  # Readiness marker for this session (sentinel echo, per DESIGN §11.2).
  local ready="<<<TMT_READY:$name>>>"
  reg_write "$name" "$type" "$opening" "$iso" "$location" "$branch" "$ready"

  # Launch the opening command / agent.
  [[ -n "$opening" ]] && _send_line "$name" "$opening"

  printf '%s✓ dispatched%s %s  type=%s iso=%s\n  location: %s%s\n' \
    "$c_grn" "$c_reset" "$name" "$type" "$iso" "$location" \
    "${branch:+$'\n'  branch: $branch}"
}

# Emit a digest a coding agent can read to summarize/decide input.
cmd_agent_scan() {
  have_tmux
  local filter='*' json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter) filter="$2"; shift 2 ;;
      --json)   json=1; shift ;;
      *) shift ;;
    esac
  done

  if [[ $json -eq 1 ]]; then
    need jq
    local first=1
    printf '['
    while IFS= read -r sess; do
      [[ -z "$sess" ]] && continue
      local line st rest cmd tail type task iso
      line=$(detect "$sess")
      st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}
      tail=$(tmux capture-pane -t "$sess" -p -S -20 2>/dev/null)
      type=$(reg_get "$sess" type); task=$(reg_get "$sess" task); iso=$(reg_get "$sess" isolation)
      [[ $first -eq 0 ]] && printf ','
      first=0
      jq -n --arg s "$sess" --arg st "$st" --arg c "$cmd" --arg t "$tail" \
            --arg ty "$type" --arg ta "$task" --arg is "$iso" \
        '{session:$s, state:$st, fg_process:$c, type:$ty, task:$ta, isolation:$is, pane_tail:$t}'
    done < <(list_sessions "$filter")
    printf ']\n'
  else
    while IFS= read -r sess; do
      [[ -z "$sess" ]] && continue
      local line st rest cmd
      line=$(detect "$sess")
      st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}
      printf '### session: %s\nstate: %s\nfg_process: %s\n--- pane tail ---\n' "$sess" "$st" "$cmd"
      tmux capture-pane -t "$sess" -p -S -20 2>/dev/null
      printf '\n\n'
    done < <(list_sessions "$filter")
  fi
}

# --- ask: send-and-await-reply (Phase B) --------------------------------------
#
# tmt ask SESSION [--timeout S] [--quiescent S] [--lines N] -- "prompt"
#
# Sends a prompt with an embedded marker, waits for the agent to complete its
# turn (quiescence + ready-box or question-prompt), then extracts and returns
# only the new output between the marker and the input box as JSON.

cmd_ask() {
  have_tmux
  need jq
  local sess="${1:?usage: tmt ask SESSION [--timeout S] [--quiescent S] [--lines N] -- PROMPT}"; shift
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"

  local timeout=300 quiescent=5 lines=5000
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout)   timeout="$2"; shift 2 ;;
      --quiescent) quiescent="$2"; shift 2 ;;
      --lines)     lines="$2"; shift 2 ;;
      --)          shift; break ;;
      *)           break ;;
    esac
  done
  local prompt="$*"
  [[ -z "$prompt" ]] && die "ask: no prompt provided"

  _lock_acquire "$sess"
  trap '_lock_release "$sess"; trap - RETURN' RETURN

  # Generate a unique marker. The wire text is one line: marker + prompt.
  local id="$$-$SECONDS"
  local marker="<<<TMT_ASK:$id>>>"
  local wire="$marker $prompt"

  # Clear prior ask-hash state so the quiescence timer starts fresh.
  rm -f "$STATE_DIR/$(key_of "$sess").ask.hash"

  # Send the marker+prompt as one turn.
  _send_line "$sess" "$wire" || die "ask: send failed"

  # Poll once/second until done, blocked, or timeout.
  local elapsed=0 state="active"
  while [[ "$elapsed" -lt "$timeout" ]]; do
    sleep 1
    elapsed=$((elapsed + 1))
    state=$(_turn_done "$sess" "$quiescent")
    [[ "$state" == "active" ]] && continue
    break
  done
  [[ "$state" == "active" ]] && state="timeout"

  # Capture and extract the reply region.
  local pane reply=""
  pane=$(tmux capture-pane -t "$sess" -p -S "-$lines" 2>/dev/null)

  # Anchor on the FIRST occurrence of our marker: that is the echoed input
  # line. The marker is unique per ask, so stale scrollback can't match; a
  # LATER occurrence can only be the agent quoting our prompt back (part of
  # the reply), which must not swallow the reply region.
  local marker_line_num
  marker_line_num=$(printf '%s\n' "$pane" | grep -nF "$marker" | head -1 | cut -d: -f1)

  if [[ -n "$marker_line_num" ]]; then
    # Everything after the marker line, then trim trailing ready-box/blanks.
    reply=$(printf '%s\n' "$pane" | tail -n "+$((marker_line_num + 1))" | _trim_trailing_ready)
    # The marker is tmt plumbing: scrub any echo of it from the reply body.
    reply=${reply//"$marker"/}
  fi

  # Clean up the ask-hash state file.
  rm -f "$STATE_DIR/$(key_of "$sess").ask.hash"

  # Output JSON.
  local exit_code=0
  [[ "$state" == "timeout" ]] && exit_code=$EX_TIMEOUT
  jq -n --arg sess "$sess" --arg id "$id" --arg status "$state" \
        --argjson elapsed "$elapsed" --arg reply "$reply" \
    '{session:$sess, id:$id, status:$status, elapsed_s:$elapsed, reply:$reply}'
  return "$exit_code"
}

# Trim trailing lines that match READY_RE or are blank. Reads stdin, writes stdout.
_trim_trailing_ready() {
  local -a buf=()
  while IFS= read -r line || [[ -n "$line" ]]; do
    buf+=("$line")
  done
  # Walk backward, dropping ready-box and blank lines.
  local i=${#buf[@]}
  while [[ $i -gt 0 ]]; do
    i=$((i - 1))
    local l="${buf[$i]}"
    if [[ -z "${l// /}" ]] || [[ "$l" =~ $READY_RE ]]; then
      unset 'buf[i]'
    else
      break
    fi
  done
  # Print remaining lines (preserving order).
  local line
  for line in "${buf[@]+"${buf[@]}"}"; do
    printf '%s\n' "$line"
  done
}

# --- serve: live HTML dashboard -------------------------------------------
#
# Serves a static index.html shell once, plus a data.json the shell polls every
# $interval seconds. A small client-side script fetches data.json and updates
# only the changed card contents in place — so the page never reloads, each
# terminal's scroll position is preserved, and the selected status tab stays
# put. Read-only: it never sends input.
#
# Bound to 127.0.0.1 only — panes can contain secrets, so we never expose them
# on the network.

# Write the live session data as JSON to stdout: an object with a per-state
# count map and an ordered sessions array. detect() mutates per-session hash
# state, so it must be called exactly once per session here.
# Args: filter lines
_serve_render_json() {
  local filter="$1" lines="$2"
  local now; now=$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date)

  local first=1
  local sessions_json=''
  local c_running=0 c_waiting=0 c_stale=0 c_idle=0 c_other=0 n=0
  local sess line st rest cmd task pane obj
  while IFS= read -r sess; do
    [[ -z "$sess" ]] && continue
    line=$(detect "$sess")
    st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}
    task=$(reg_get "$sess" task)
    pane=$(tmux capture-pane -t "$sess" -p -S "-$lines" 2>/dev/null)
    case "$st" in
      RUNNING) c_running=$((c_running+1)) ;;
      WAITING) c_waiting=$((c_waiting+1)) ;;
      STALE)   c_stale=$((c_stale+1)) ;;
      IDLE)    c_idle=$((c_idle+1)) ;;
      *)       c_other=$((c_other+1)) ;;
    esac
    n=$((n+1))
    obj=$(jq -n --arg s "$sess" --arg st "$st" --arg c "$cmd" \
                --arg t "$task" --arg p "$pane" \
      '{session:$s, state:$st, fg_process:$c, task:$t, pane:$p}')
    if [[ $first -eq 1 ]]; then sessions_json="$obj"; first=0
    else sessions_json="$sessions_json,$obj"; fi
  done < <(list_sessions "$filter")

  jq -n --arg now "$now" --arg filter "$filter" \
        --argjson running "$c_running" --argjson waiting "$c_waiting" \
        --argjson stale "$c_stale" --argjson idle "$c_idle" \
        --argjson other "$c_other" --argjson n "$n" \
        --argjson sessions "[${sessions_json}]" \
    '{updated:$now, filter:$filter, n:$n,
      counts:{running:$running, waiting:$waiting, stale:$stale, idle:$idle, other:$other},
      sessions:$sessions}'
}

# Write the static dashboard shell to stdout. It is generated once; all live
# updates happen client-side by polling data.json.
# Args: filter interval
_serve_render_shell() {
  local filter="$1" interval="$2"
  local interval_ms=$((interval * 1000))
  cat <<HTMLHEAD
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>tmt dashboard</title>
<style>
  :root { color-scheme: light dark; }
  * { box-sizing: border-box; }
  body { font: 14px/1.5 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
         margin: 0; padding: 1.2rem; background: #0b0f14; color: #d7dde3; }
  h1 { font-size: 1.1rem; margin: 0 0 .2rem; }
  .meta { color: #7d8794; font-size: .82rem; margin-bottom: 1rem; }
  /* Status tabs via :target — the URL fragment (#waiting, ...) selects a panel
     with zero page reloads; JS only swaps card contents, so the tab persists. */
  .tabs { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .tab { padding: .2rem .7rem; border-radius: 999px; font-size: .8rem;
         border: 1px solid #263040; text-decoration: none; color: #9aa4b0;
         background: #0f151d; }
  .tab .count { opacity: .7; }
  .panel { display: none; }
  .panel:target { display: block; }
  /* Default view = the "all" panel (placed LAST in the DOM). Any earlier
     panel being :target hides it; when #all itself is the target it shows. */
  #all { display: block; }
  .panel:target ~ #all { display: none; }
  .panel-empty { color: #7d8794; padding: 1.5rem; text-align: center;
                 border: 1px dashed #263040; border-radius: 8px; }
  .card { border: 1px solid #263040; border-radius: 8px; margin-bottom: 1rem;
          overflow: hidden; background: #0f151d; }
  .card > header { display: flex; align-items: center; gap: .6rem;
                   padding: .55rem .8rem; background: #141c26; }
  .dot { width: .7rem; height: .7rem; border-radius: 50%; flex: 0 0 auto; }
  .name { font-weight: 700; }
  .fg { color: #7d8794; font-size: .8rem; margin-left: auto; }
  .task { color: #9aa4b0; font-size: .8rem; }
  .state-tag { font-size: .72rem; padding: .05rem .45rem; border-radius: 4px;
               border: 1px solid currentColor; }
  pre { margin: 0; padding: .7rem .8rem; overflow-x: auto; white-space: pre-wrap;
        word-break: break-word; max-height: 22rem; overflow-y: auto;
        font-size: .8rem; color: #c2cad3; }
  .running { color: #4ade80; } .waiting { color: #fbbf24; }
  .stale   { color: #f87171; } .idle    { color: #6b7480; }
  .unknown { color: #9aa4b0; }
  .dot.running { background:#4ade80; } .dot.waiting { background:#fbbf24; }
  .dot.stale   { background:#f87171; } .dot.idle    { background:#6b7480; }
  .dot.unknown { background:#9aa4b0; }
  .stale-conn { opacity: .55; }
</style>
</head>
<body>
<h1>tmt — live session dashboard</h1>
<div class="meta" id="meta">filter <code>$filter</code> · refresh ${interval}s · connecting…</div>
<nav class="tabs">
  <a class="tab" href="#all">all <span class="count" id="cnt-all">0</span></a>
  <a class="tab waiting" href="#waiting">⏳ waiting <span class="count" id="cnt-waiting">0</span></a>
  <a class="tab stale"   href="#stale">■ stale <span class="count" id="cnt-stale">0</span></a>
  <a class="tab running" href="#running">▶ running <span class="count" id="cnt-running">0</span></a>
  <a class="tab idle"    href="#idle">· idle <span class="count" id="cnt-idle">0</span></a>
</nav>
<section class="panel" id="waiting"></section>
<section class="panel" id="stale"></section>
<section class="panel" id="running"></section>
<section class="panel" id="idle"></section>
<section class="panel" id="all"></section>
<script>
// Poll data.json and reconcile cards in place. We never reload the page or
// replace whole panels wholesale — cards are keyed by session name and moved
// with appendChild, so each <pre>'s scroll position and the selected tab (a
// URL :target) are preserved across updates. Only changed text is rewritten.
const INTERVAL = $interval_ms;
const STATE_CLASS = {RUNNING:'running', WAITING:'waiting', STALE:'stale', IDLE:'idle'};
const TAG = {RUNNING:'▶', WAITING:'⏳', STALE:'■', IDLE:'·'};
// Which sessions land in each panel, and in what order.
const ATTENTION = ['WAITING','STALE','RUNNING','IDLE','OTHER'];
function stateClass(s){ return STATE_CLASS[s] || 'unknown'; }

// Build (once) or update (in place) one card node for a session in a panel.
function upsertCard(panel, sess, key){
  const id = 'card-' + panel.id + '-' + key;
  let card = document.getElementById(id);
  if(!card){
    card = document.createElement('div');
    card.className = 'card';
    card.id = id;
    card.innerHTML =
      '<header>' +
        '<span class="dot"></span>' +
        '<span class="name"></span>' +
        '<span class="state-tag"></span>' +
        '<span class="task"></span>' +
        '<span class="fg"></span>' +
      '</header><pre></pre>';
  }
  const kl = stateClass(sess.state);
  card.querySelector('.dot').className = 'dot ' + kl;
  const nm = card.querySelector('.name');
  if(nm.textContent !== sess.session) nm.textContent = sess.session;
  const tg = card.querySelector('.state-tag');
  tg.className = 'state-tag ' + kl;
  const tgtext = (TAG[sess.state]||'') + ' ' + sess.state;
  if(tg.textContent !== tgtext) tg.textContent = tgtext;
  const tk = card.querySelector('.task');
  const tkv = sess.task || '';
  if(tk.textContent !== tkv) tk.textContent = tkv;
  tk.style.display = tkv ? '' : 'none';
  const fg = card.querySelector('.fg');
  if(fg.textContent !== sess.fg_process) fg.textContent = sess.fg_process;
  const pre = card.querySelector('pre');
  // Only rewrite the terminal text when it actually changed, so we don't stomp
  // a user's scroll mid-read. Setting textContent resets scrollTop to 0, so we
  // capture the position first and restore it: if they were pinned to the
  // bottom, keep following new output; otherwise leave their scroll exactly
  // where it was so they can read at their own pace.
  if(pre.textContent !== sess.pane){
    const prevTop = pre.scrollTop;
    const atBottom = prevTop + pre.clientHeight >= pre.scrollHeight - 4;
    pre.textContent = sess.pane;
    pre.scrollTop = atBottom ? pre.scrollHeight : prevTop;
  }
  return card;
}

// Reconcile a panel to exactly the given ordered list of sessions.
function syncPanel(panelId, list){
  const panel = document.getElementById(panelId);
  const wanted = new Set();
  if(list.length === 0){
    panel.innerHTML = '<div class="panel-empty">no ' +
      (panelId === 'all' ? '' : panelId + ' ') + 'sessions</div>';
    return;
  }
  // Drop the empty-state placeholder if present.
  const ph = panel.querySelector('.panel-empty');
  if(ph) ph.remove();
  list.forEach(sess => {
    const key = encodeURIComponent(sess.session);
    wanted.add('card-' + panelId + '-' + key);
    const card = upsertCard(panel, sess, key);
    panel.appendChild(card); // moves existing node into order, preserves scroll
  });
  // Remove cards for sessions no longer in this panel.
  Array.from(panel.children).forEach(c => {
    if(c.id && !wanted.has(c.id)) c.remove();
  });
}

function render(data){
  document.getElementById('meta').innerHTML =
    'filter <code>' + escapeHtml(data.filter) + '</code> · updated ' +
    escapeHtml(data.updated) + ' · ' + data.n + ' session(s)';
  const c = data.counts;
  document.getElementById('cnt-all').textContent = data.n;
  document.getElementById('cnt-waiting').textContent = c.waiting;
  document.getElementById('cnt-stale').textContent = c.stale;
  document.getElementById('cnt-running').textContent = c.running;
  document.getElementById('cnt-idle').textContent = c.idle;
  const by = {WAITING:[], STALE:[], RUNNING:[], IDLE:[], OTHER:[]};
  data.sessions.forEach(s => (by[s.state] || by.OTHER).push(s));
  syncPanel('waiting', by.WAITING);
  syncPanel('stale',   by.STALE);
  syncPanel('running', by.RUNNING);
  syncPanel('idle',    by.IDLE);
  // "all" is attention-ordered.
  const all = [];
  ATTENTION.forEach(st => (by[st] || []).forEach(s => all.push(s)));
  syncPanel('all', all);
  document.body.classList.remove('stale-conn');
}
function escapeHtml(s){ return String(s).replace(/[&<>]/g,
  m => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[m])); }

async function poll(){
  try {
    const r = await fetch('data.json?_=' + Date.now(), {cache:'no-store'});
    if(r.ok) render(await r.json());
    else document.body.classList.add('stale-conn');
  } catch(e){ document.body.classList.add('stale-conn'); }
}
poll();
setInterval(poll, INTERVAL);
</script>
</body>
</html>
HTMLHEAD
}

cmd_serve() {
  have_tmux
  need python3
  need jq
  local filter='*' interval=3 port=8787 lines=40
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter)   filter="$2"; shift 2 ;;
      --interval) interval="$2"; shift 2 ;;
      --port)     port="$2"; shift 2 ;;
      --lines)    lines="$2"; shift 2 ;;
      *) die "serve: unknown option: $1" ;;
    esac
  done
  [[ "$interval" =~ ^[0-9]+$ && "$interval" -ge 1 ]] || die "serve: --interval must be a positive integer"
  [[ "$port" =~ ^[0-9]+$ ]] || die "serve: --port must be a number"
  [[ "$lines" =~ ^[0-9]+$ ]] || die "serve: --lines must be a number"

  # Serve out of a private temp dir so the http.server can't expose anything
  # else. Cleaned up on exit.
  local webdir; webdir=$(mktemp -d "$STATE_DIR/serve.XXXXXX") || die "cannot create temp dir"

  # The shell is static: write it once. Live state flows through data.json.
  _serve_render_shell "$filter" "$interval" > "$webdir/index.html"
  # Seed the first data.json so the initial paint has data, not "connecting…".
  _serve_render_json "$filter" "$lines" > "$webdir/data.json" 2>/dev/null

  # Background refresher: regenerate data.json every $interval seconds. The
  # browser polls it and updates cards in place (no page reload).
  ( while true; do
      sleep "$interval"
      _serve_render_json "$filter" "$lines" > "$webdir/data.json.tmp" 2>/dev/null
      mv -f "$webdir/data.json.tmp" "$webdir/data.json"
    done ) &
  local refresher=$!

  printf '%s✓ dashboard%s http://127.0.0.1:%s/  (filter=%s refresh=%ss)\n' \
    "$c_grn" "$c_reset" "$port" "$filter" "$interval"
  printf '%sread-only; Ctrl-C to stop%s\n' "$c_dim" "$c_reset"

  # Start the server (bind localhost only) as a tracked child so we can kill it
  # on any exit path — not just interactive Ctrl-C, which would hit the whole
  # process group anyway.
  ( cd "$webdir" && exec python3 -m http.server "$port" --bind 127.0.0.1 ) 2>/dev/null &
  local server=$!

  # Clean up both children and the temp dir however we exit.
  trap 'kill "$refresher" "$server" 2>/dev/null; rm -rf "$webdir"' EXIT INT TERM

  # Block until the server exits (Ctrl-C, or the port dies).
  wait "$server"
}

# --- save / restore -------------------------------------------------------
#
# A snapshot is a tab-separated file, one line per pane:
#   session <TAB> window_index <TAB> window_name <TAB> pane_index <TAB>
#   window_layout <TAB> cwd <TAB> foreground_command
# Comment lines (#) carry metadata. This mirrors what tmux-resurrect stores:
# it recreates the session *layout* and re-runs the foreground command; it
# cannot revive process memory (nothing can, across a reboot).

# Return the foreground command line for a pane's tty (empty if just a shell).
_pane_fg_cmd() {
  local tty="${1#/dev/}"
  # stat with '+' = foreground process group; skip the login shell itself.
  ps -t "$tty" -o stat=,args= 2>/dev/null | awk '
    $1 ~ /\+/ {
      cmd=$0; sub(/^[[:space:]]*[^[:space:]]+[[:space:]]+/, "", cmd)   # drop stat col
      if (cmd ~ /^-?(bash|zsh|sh|fish|dash|tcsh|ksh)$/) next            # bare shell
      print cmd; exit
    }'
}

# Escape a field for our TSV (newlines/tabs would corrupt the format).
_tsv() { printf '%s' "$1" | tr '\n\t' '  '; }

cmd_save() {
  have_tmux
  local filter='*' name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter) filter="$2"; shift 2 ;;
      --name)   name="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  local stamp file
  stamp=$(date +%Y%m%d-%H%M%S)
  file="$SNAP_DIR/${name:-snapshot}-$stamp.tsv"

  {
    printf '# tmux-tasks snapshot v1\n'
    printf '# created %s  filter %s  host %s\n' "$(date -Iseconds 2>/dev/null || date)" "$filter" "$(hostname 2>/dev/null)"
    while IFS= read -r sess; do
      [[ -z "$sess" ]] && continue
      while IFS=$'\t' read -r win winname pane layout cwd tty; do
        local fg; fg=$(_pane_fg_cmd "$tty")
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
          "$(_tsv "$sess")" "$win" "$(_tsv "$winname")" "$pane" \
          "$(_tsv "$layout")" "$(_tsv "$cwd")" "$(_tsv "$fg")"
      done < <(tmux list-panes -s -t "$sess" \
                 -F $'#{window_index}\t#{window_name}\t#{pane_index}\t#{window_layout}\t#{pane_current_path}\t#{pane_tty}' 2>/dev/null)
    done < <(list_sessions "$filter")
  } > "$file"

  # keep a stable "latest" pointer and prune old snapshots
  ln -sf "$(basename "$file")" "$SNAP_DIR/latest.tsv"
  ls -1t "$SNAP_DIR"/*.tsv 2>/dev/null | grep -v '/latest.tsv$' | tail -n +$((SNAP_KEEP+1)) | xargs -r rm -f

  local n; n=$(grep -vc '^#' "$file")
  printf '%s✓ saved%s %s panes -> %s\n' "$c_grn" "$c_reset" "$n" "$file"
}

cmd_snapshots() {
  local f n created
  if ! ls "$SNAP_DIR"/*.tsv &>/dev/null; then
    printf '%sno snapshots yet (run: tmt save)%s\n' "$c_dim" "$c_reset"; return
  fi
  printf '%s%-40s %-8s %s%s\n' "$c_bold" "SNAPSHOT" "PANES" "CREATED" "$c_reset"
  for f in $(ls -1t "$SNAP_DIR"/*.tsv 2>/dev/null); do
    [[ "$(basename "$f")" == latest.tsv ]] && continue
    n=$(grep -vc '^#' "$f")
    created=$(sed -n 's/^# created \([^ ]*\).*/\1/p' "$f" | head -1)
    printf '%-40s %-8s %s\n' "$(basename "$f")" "$n" "$created"
  done
  [[ -L "$SNAP_DIR/latest.tsv" ]] && printf '%slatest -> %s%s\n' "$c_dim" "$(readlink "$SNAP_DIR/latest.tsv")" "$c_reset"
}

# Resolve a snapshot argument to a path: empty=latest, a name, or a full path.
_snap_path() {
  local arg="${1:-}"
  if [[ -z "$arg" ]]; then printf '%s' "$SNAP_DIR/latest.tsv"; return; fi
  [[ -f "$arg" ]] && { printf '%s' "$arg"; return; }
  [[ -f "$SNAP_DIR/$arg" ]] && { printf '%s' "$SNAP_DIR/$arg"; return; }
  [[ -f "$SNAP_DIR/$arg.tsv" ]] && { printf '%s' "$SNAP_DIR/$arg.tsv"; return; }
  return 1
}

cmd_restore() {
  need tmux
  local dry=0 run=0 snap=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run|-n) dry=1; shift ;;
      --run)        run=1; shift ;;   # also re-run captured commands
      *)            snap="$1"; shift ;;
    esac
  done
  local file
  file=$(_snap_path "$snap") || die "snapshot not found: ${snap:-latest} (see: tmt snapshots)"

  # Restore is session-level: one tmux session per task (matches how tmt is
  # used). We act on the first pane line seen per session; additional
  # panes/windows in the snapshot are informational only. Full multi-pane
  # layout revival is intentionally out of scope.
  local created=0 skipped=0
  local seen=" "
  while IFS=$'\t' read -r sess win winname pane layout cwd fg; do
    [[ "$sess" == \#* || -z "$sess" ]] && continue
    case "$seen" in *" $sess "*) continue ;; esac   # first line per session only
    seen+="$sess "

    if [[ $dry -eq 1 ]]; then
      printf '%swould restore%s %s  cwd=%s%s%s\n' \
        "$c_cyn" "$c_reset" "$sess" "$cwd" "${fg:+  cmd=}" "$fg"
      continue
    fi

    if tmux has-session -t "$sess" 2>/dev/null; then
      skipped=$((skipped+1)); continue
    fi
    tmux new-session -d -s "$sess" -c "$cwd" 2>/dev/null && created=$((created+1))
    [[ -n "$fg" && $run -eq 1 ]] && _send_line "$sess" "$fg"
  done < "$file"

  if [[ $dry -eq 1 ]]; then
    printf '%s(dry run — nothing changed)%s\n' "$c_dim" "$c_reset"
  else
    printf '%s✓ restored%s %s session(s), skipped %s existing  (from %s)\n' \
      "$c_grn" "$c_reset" "$created" "$skipped" "$(basename "$file")"
    [[ $run -eq 0 ]] && printf '%stip: re-run captured commands with --run%s\n' "$c_dim" "$c_reset"
  fi
}

cmd_watch() {
  have_tmux
  local filter='*' interval=3
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter)   filter="$2"; shift 2 ;;
      --interval) interval="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  while true; do
    printf '\033[H\033[2J'  # home + clear
    printf '%stmt%s  filter=%s  %s(refresh %ss)%s\n\n' "$c_bold$c_cyn" "$c_reset" "$filter" "$c_dim" "$interval" "$c_reset"
    render_table "$filter"
    printf '\n%s[#]attach  [s]end-input  [c]apture  [k]ey  [r]efresh  [q]uit%s\n> ' "$c_dim" "$c_reset"

    local input=''
    read -r -t "$interval" input || { continue; }   # timeout → auto-refresh
    [[ -z "$input" ]] && continue

    case "$input" in
      q|quit) printf 'bye\n'; break ;;
      r)      continue ;;
      s)      _interactive_send ;;
      c)      _interactive_capture ;;
      k)      _interactive_key ;;
      [0-9]*) _interactive_attach "$input" ;;
      *) ;;
    esac
  done
}

_pick() {  # echo session name for an index, or empty
  local idx="$1"
  [[ "$idx" =~ ^[0-9]+$ ]] || return 1
  [[ -n "${SESS[idx]:-}" ]] && printf '%s' "${SESS[idx]}"
}

_interactive_attach() {
  local sess; sess=$(_pick "$1") || { printf 'no such #\n'; sleep 1; return; }
  [[ -z "$sess" ]] && { printf 'no such #\n'; sleep 1; return; }
  printf 'attaching to %s (detach with ctrl-b d)...\n' "$sess"; sleep 0.5
  tmux attach -t "$sess"
}

_interactive_send() {
  printf 'session #: '; local n; read -r n
  local sess; sess=$(_pick "$n") || { printf 'bad #\n'; sleep 1; return; }
  [[ -z "$sess" ]] && { printf 'bad #\n'; sleep 1; return; }
  printf '%slast line of %s:%s\n' "$c_dim" "$sess" "$c_reset"
  tmux capture-pane -t "$sess" -p 2>/dev/null | grep -v '^[[:space:]]*$' | tail -n 1
  printf 'text to send (Enter appended): '; local text; read -r text
  printf 'send %s"%s"%s to %s? [y/N] ' "$c_yel" "$text" "$c_reset" "$sess"
  local ok; read -r ok
  [[ "$ok" == y || "$ok" == Y ]] && _send_line "$sess" "$text" && { printf 'sent.\n'; sleep 0.6; }
}

_interactive_key() {
  printf 'session #: '; local n; read -r n
  local sess; sess=$(_pick "$n") || { printf 'bad #\n'; sleep 1; return; }
  [[ -z "$sess" ]] && { printf 'bad #\n'; sleep 1; return; }
  printf 'tmux key(s) to send (e.g. Enter, C-c, y Enter): '; local keys; read -r keys
  # shellcheck disable=SC2086
  tmux send-keys -t "$sess" $keys && { printf 'sent.\n'; sleep 0.6; }
}

_interactive_capture() {
  printf 'session #: '; local n; read -r n
  local sess; sess=$(_pick "$n") || { printf 'bad #\n'; sleep 1; return; }
  [[ -z "$sess" ]] && { printf 'bad #\n'; sleep 1; return; }
  printf '\033[2J\033[H'
  cmd_status "$sess"
  printf '\n%s[enter to return]%s' "$c_dim" "$c_reset"; read -r _
}

# Print the leading comment header (lines 3.. up to the first non-comment line),
# stripping the leading "# ". Robust to the header changing length.
usage() {
  awk 'NR<3{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
}

main() {
  local sub="${1:-watch}"; shift || true
  case "$sub" in
    watch)       cmd_watch "$@" ;;
    ls|list)     cmd_ls "$@" ;;
    status)      cmd_status "$@" ;;
    capture)     cmd_capture "$@" ;;
    send)        cmd_send "$@" ;;
    ask)         cmd_ask "$@" ;;
    key)         cmd_key "$@" ;;
    new)         cmd_new "$@" ;;
    dispatch)    cmd_dispatch "$@" ;;
    registry)    cmd_registry "$@" ;;
    save)        cmd_save "$@" ;;
    restore)     cmd_restore "$@" ;;
    snapshots)   cmd_snapshots "$@" ;;
    agent-scan)  cmd_agent_scan "$@" ;;
    serve)       cmd_serve "$@" ;;
    attach)      cmd_attach "$@" ;;
    version|--version|-V) printf 'tmt (tmux-tasks) %s\n' "$TMT_VERSION" ;;
    -h|--help|help) usage ;;
    # Hidden test hooks (not in help/completions): let test.sh exercise the
    # lock helpers in-process.
    _test_lock_acquire) _lock_acquire "$@" ;;
    _test_lock_release) _lock_release "$@" ;;
    _test_turn_done)    _turn_done "$@" ;;
    *) die "unknown subcommand: $sub (try: tmt --help)" ;;
  esac
}

main "$@"
