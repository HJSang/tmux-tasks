#!/usr/bin/env bash
#
# tmt (tmux-tasks) — monitor & interact with per-task tmux sessions from one place.
#
# You run each task in its own tmux session. This tool lists them, detects
# whether each is running / idle / waiting-for-input, shows a live table, and
# lets you send input to a session without attaching. It also has an
# `agent-scan` subcommand that emits a compact digest a coding agent can read
# to interpret status and decide what input to send.
#
# Subcommands:
#   watch [--filter GLOB] [--interval N]   Live table + single-key actions (default)
#   ls    [--filter GLOB]                   One-shot table, then exit
#   status SESSION                          Detailed view of one session
#   capture SESSION [--lines N]             Dump a session's pane (for humans/agents)
#   send  SESSION -- TEXT...                Send a line of input to a session
#   key   SESSION KEY...                    Send raw tmux keys (e.g. Enter, C-c, y)
#   new   NAME [-- CMD...]                   Create a task session (optionally run CMD)
#   dispatch NAME --type T [--isolation worktree|cwd] [--repo D] [--branch B]
#            [--cwd D] -- "CMD"              Create one isolated giant task + register it
#   registry [SESSION]                       Show session metadata (JSON)
#   save  [--filter GLOB] [--name NAME]     Snapshot session layout+cwd+cmd to disk
#   restore [SNAPSHOT] [--run] [--dry-run]  Recreate sessions from a snapshot
#   snapshots                               List saved snapshots
#   agent-scan [--filter GLOB] [--json]     Digest of all sessions for an agent
#   serve [--filter GLOB] [--interval N] [--port P] [--lines N]
#                                           Live HTML dashboard (localhost, auto-refresh)
#   attach SESSION                          Attach to a session (exits monitor)
#   version                                 Print version
#
# Reboot safety: a reboot kills every process, so no tool can revive a running
# build or a live agent. `tmt save` snapshots the session *layout* (name, cwd,
# and the foreground command). After reboot, `tmt restore --run` recreates the
# sessions and re-launches those commands. Snapshots live in
# ~/.local/share/tmux-tasks/ (persistent, not /tmp).
#
# State detection (mixed CLI tools):
#   RUNNING  a non-shell process is foreground and output is moving
#   WAITING  last line looks like an interactive prompt (y/n, password, ?, :)
#   IDLE     foreground process is a shell (nothing running)
#   STALE    non-shell process but output unchanged since last scan (maybe hung)

set -uo pipefail

TMT_VERSION="0.3.1"

# Stable exit codes (see DESIGN.md §5) so a program consumer can branch on them.
EX_OK=0; EX_USAGE=2; EX_NOSESSION=3; EX_LOCKED=4; EX_POLICY=5; EX_NOTMUX=6; EX_TIMEOUT=7

# Data root. Everything persistent lives here (NOT /tmp, which reboots wipe).
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tmux-tasks"

# Ephemeral scan state (pane hashes for RUNNING vs STALE). OK to lose on reboot.
STATE_DIR="${TMPDIR:-/tmp}/tmux-tasks-${USER:-$(id -un)}"
mkdir -p "$STATE_DIR"

# Persistent snapshots for save/restore.
SNAP_DIR="$DATA_DIR/snapshots"
mkdir -p "$SNAP_DIR"
SNAP_KEEP=20   # how many timestamped snapshots to retain

# Persistent per-session metadata (type, task, isolation, ready-pattern, ...).
REG_DIR="$DATA_DIR/registry"
mkdir -p "$REG_DIR"

SHELLS='^(bash|zsh|sh|fish|dash|tcsh|ksh|-bash|-zsh)$'

# Prompt patterns that indicate a program is blocked waiting for the user.
PROMPT_RE='(\?[[:space:]]*$|\((y|Y)(es)?/(n|N)(o)?\)|\[[yYnN]/[yYnN]\]|[Pp]assword.*:|[Pp]assphrase.*:|[Cc]ontinue\??|[Pp]roceed|[Oo]verwrite|\[y/N\]|\[Y/n\]|press[[:space:]]+enter|:[[:space:]]*$|❯[[:space:]]*$|»[[:space:]]*$)'

# Colors only when stdout is a real terminal, so a program consuming our output
# (the orchestrator) never has to strip ANSI. NO_COLOR=1 also disables them.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  c_reset=$'\033[0m'; c_dim=$'\033[2m'; c_bold=$'\033[1m'
  c_red=$'\033[31m'; c_grn=$'\033[32m'; c_yel=$'\033[33m'; c_blu=$'\033[34m'; c_cyn=$'\033[36m'
else
  c_reset=''; c_dim=''; c_bold=''; c_red=''; c_grn=''; c_yel=''; c_blu=''; c_cyn=''
fi

# die [CODE] MESSAGE...  — default code EX_USAGE.
die() {
  local code=$EX_USAGE
  [[ "${1:-}" =~ ^[0-9]+$ ]] && { code="$1"; shift; }
  printf '%s\n' "$*" >&2; exit "$code"
}
need() { command -v "$1" &>/dev/null || die "required command not found: $1"; }
have_tmux() { need tmux; tmux info &>/dev/null || die "$EX_NOTMUX" "no tmux server running (start a session first)"; }

# List session names, optionally filtered by a glob against the name.
list_sessions() {
  local filter="${1:-*}"
  tmux list-sessions -F '#{session_name}' 2>/dev/null | while IFS= read -r s; do
    # shellcheck disable=SC2053
    [[ "$s" == $filter ]] && printf '%s\n' "$s"
  done
}

# Sanitize a session name into a filename-safe key.
key_of() { printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'; }

# Detect state for a session. Echoes: "STATE<TAB>CMD<TAB>LASTLINE"
detect() {
  local sess="$1"
  local cmd pane last hash prev statef
  cmd=$(tmux display-message -t "$sess" -p '#{pane_current_command}' 2>/dev/null)
  pane=$(tmux capture-pane -t "$sess" -p 2>/dev/null)
  last=$(printf '%s\n' "$pane" | grep -v '^[[:space:]]*$' | tail -n 1)
  hash=$(printf '%s' "$pane" | cksum | cut -d' ' -f1)

  statef="$STATE_DIR/$(key_of "$sess").hash"
  prev=""; [[ -f "$statef" ]] && prev=$(<"$statef")
  printf '%s' "$hash" > "$statef"

  local state
  if [[ "$last" =~ $PROMPT_RE ]]; then
    state="WAITING"
  elif [[ "$cmd" =~ $SHELLS ]]; then
    state="IDLE"
  elif [[ -n "$prev" && "$prev" == "$hash" ]]; then
    state="STALE"
  else
    state="RUNNING"
  fi
  printf '%s\t%s\t%s\n' "$state" "$cmd" "$last"
}

state_color() {
  case "$1" in
    RUNNING) printf '%s' "$c_grn" ;;
    WAITING) printf '%s' "$c_yel" ;;
    STALE)   printf '%s' "$c_red" ;;
    IDLE)    printf '%s' "$c_dim" ;;
    *)       printf '%s' "$c_reset" ;;
  esac
}

state_icon() {
  case "$1" in
    RUNNING) printf '▶' ;;
    WAITING) printf '⏳' ;;
    STALE)   printf '■' ;;
    IDLE)    printf '·' ;;
    *)       printf '?' ;;
  esac
}

# Print the table. Populates global arrays SESS[] and STATE[] for interactive use.
declare -a SESS STATE
render_table() {
  local filter="${1:-*}"
  SESS=(); STATE=()
  local i=0 sess line st rest cmd last
  printf '%s%-3s %-2s %-9s %-26s %s%s\n' "$c_bold" "#" "" "STATE" "SESSION" "LAST LINE" "$c_reset"
  while IFS= read -r sess; do
    [[ -z "$sess" ]] && continue
    line=$(detect "$sess")
    st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}; last=${rest#*$'\t'}
    SESS[i]="$sess"; STATE[i]="$st"
    last=${last:0:60}
    printf '%s%-3s %s%-2s %-9s%s %-26s %s%s%s\n' \
      "$c_dim" "$i" "$(state_color "$st")" "$(state_icon "$st")" "$st" "$c_reset" \
      "${sess:0:26}" "$c_dim" "$last" "$c_reset"
    i=$((i+1))
  done < <(list_sessions "$filter")
  [[ $i -eq 0 ]] && printf '%s(no sessions match)%s\n' "$c_dim" "$c_reset"
  return 0
}

cmd_ls() {
  have_tmux
  local filter='*'
  [[ "${1:-}" == "--filter" ]] && { filter="$2"; }
  render_table "$filter"
}

cmd_status() {
  have_tmux
  local sess="${1:?usage: tmt status SESSION}"
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"
  local line st rest cmd last
  line=$(detect "$sess")
  st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}; last=${rest#*$'\t'}
  printf '%sSession:%s %s\n' "$c_bold" "$c_reset" "$sess"
  printf '%sState:  %s %s%s%s  (fg process: %s)\n' "$c_bold" "$c_reset" "$(state_color "$st")" "$st" "$c_reset" "$cmd"
  printf '%s--- last 25 lines %s\n' "$c_dim" "$c_reset"
  tmux capture-pane -t "$sess" -p -S -25 2>/dev/null
}

cmd_capture() {
  have_tmux
  local sess="${1:?usage: tmt capture SESSION [--lines N]}"; shift
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"
  local lines=100
  [[ "${1:-}" == "--lines" ]] && lines="$2"
  tmux capture-pane -t "$sess" -p -S "-$lines" 2>/dev/null
}

# Type a line into a session and submit it. Sends the TEXT and the Enter as
# TWO separate send-keys calls with a short settle delay between them.
#
# Why not one call: TUI apps (Claude Code, aider, ...) ingest a paste
# char-by-char or via bracketed-paste. When text + Enter arrive in one burst,
# the Enter is absorbed into the input box (as a literal newline, or before the
# app finishes reading the paste) instead of submitting. Splitting them — and
# waiting for the app to settle — makes the submit reliable. Plain shells are
# unaffected either way. Delay overridable via TMT_SEND_DELAY (seconds).
_send_line() {
  local sess="$1" text="$2"
  local delay="${TMT_SEND_DELAY:-0.3}"
  tmux send-keys -t "$sess" -- "$text" || return 1
  # Let the target ingest the text before we submit.
  sleep "$delay"
  tmux send-keys -t "$sess" Enter
}

cmd_send() {
  have_tmux
  local sess="${1:?usage: tmt send SESSION -- TEXT}"; shift
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"
  [[ "${1:-}" == "--" ]] && shift
  local text="$*"
  _send_line "$sess" "$text" && \
    printf '%s→ sent to %s:%s %s\n' "$c_grn" "$sess" "$c_reset" "$text"
}

cmd_key() {
  have_tmux
  local sess="${1:?usage: tmt key SESSION KEY...}"; shift
  tmux has-session -t "$sess" 2>/dev/null || die "$EX_NOSESSION" "no such session: $sess"
  tmux send-keys -t "$sess" "$@" && \
    printf '%s→ sent keys to %s:%s %s\n' "$c_grn" "$sess" "$c_reset" "$*"
}

cmd_new() {
  need tmux
  local name="${1:?usage: tmt new NAME [-- CMD...]}"; shift
  if tmux has-session -t "$name" 2>/dev/null; then
    die "session already exists: $name"
  fi
  tmux new-session -d -s "$name" || die "failed to create session: $name"
  if [[ "${1:-}" == "--" ]]; then
    shift
    _send_line "$name" "$*"
  fi
  printf '%s✓ created session%s %s\n' "$c_grn" "$c_reset" "$name"
}

cmd_attach() {
  have_tmux
  local sess="${1:?usage: tmt attach SESSION}"
  exec tmux attach -t "$sess"
}

# --- session registry -----------------------------------------------------
#
# Per-session metadata as JSON at $REG_DIR/<key>.json. Lets the orchestrator
# know WHAT each session is (type, task, isolation, ready-pattern) rather than
# only shell-vs-nonshell. Written by dispatch/new; read by agent-scan/registry.

reg_file() { printf '%s/%s.json' "$REG_DIR" "$(key_of "$1")"; }

# reg_write SESSION TYPE TASK ISOLATION LOCATION BRANCH READY
reg_write() {
  need jq
  local sess="$1" type="$2" task="$3" iso="$4" loc="$5" branch="$6" ready="$7"
  jq -n --arg s "$sess" --arg ty "$type" --arg ta "$task" --arg is "$iso" \
        --arg lo "$loc" --arg br "$branch" --arg re "$ready" \
    '{session:$s, type:$ty, task:$ta, isolation:$is, location:$lo, branch:$br, ready_pattern:$re}' \
    > "$(reg_file "$sess")"
}

# Echo a registry field, or empty if unregistered.
reg_get() {
  local f; f=$(reg_file "$1"); [[ -f "$f" ]] || return 0
  jq -r ".${2} // \"\"" "$f" 2>/dev/null
}

cmd_registry() {
  need jq
  local sess="${1:-}"
  if [[ -n "$sess" ]]; then
    local f; f=$(reg_file "$sess")
    [[ -f "$f" ]] || die "$EX_NOSESSION" "no registry entry for: $sess"
    cat "$f"; return
  fi
  # all entries as a JSON array
  local first=1; printf '['
  local f
  for f in "$REG_DIR"/*.json; do
    [[ -e "$f" ]] || continue
    [[ $first -eq 0 ]] && printf ','
    first=0; cat "$f"
  done
  printf ']\n'
}

# --- dispatch: create one isolated giant task -----------------------------
#
# tmt dispatch NAME --type TYPE [--isolation worktree|cwd] [--repo DIR]
#              [--branch B] [--cwd DIR] -- "opening prompt / command"
#
# isolation=worktree : git worktree add <repo>/../<branch> -b <branch>; cwd=there
# isolation=cwd      : run in --cwd (independent project); no worktree created
cmd_dispatch() {
  need tmux
  local name="${1:?usage: tmt dispatch NAME --type TYPE [opts] -- CMD}"; shift
  local type="shell" iso="cwd" repo="" branch="" cwd="" opening=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)      type="$2"; shift 2 ;;
      --isolation) iso="$2"; shift 2 ;;
      --repo)      repo="$2"; shift 2 ;;
      --branch)    branch="$2"; shift 2 ;;
      --cwd)       cwd="$2"; shift 2 ;;
      --)          shift; opening="$*"; break ;;
      *) die "dispatch: unknown option: $1" ;;
    esac
  done

  tmux has-session -t "$name" 2>/dev/null && die "session already exists: $name"

  local location=""
  case "$iso" in
    worktree)
      need git
      [[ -n "$repo" ]] || die "dispatch --isolation worktree requires --repo DIR"
      [[ -d "$repo/.git" || -f "$repo/.git" ]] || die "not a git repo: $repo"
      [[ -n "$branch" ]] || branch=$(key_of "$name")
      # place the worktree in a sibling dir of the repo: <repo>/../tmt-worktrees/<branch>
      local repo_abs; repo_abs=$(cd "$repo" && pwd)
      location="$(cd "$repo_abs/.." && pwd)/tmt-worktrees/$branch"
      if [[ ! -d "$location" ]]; then
        mkdir -p "$(dirname "$location")"
        git -C "$repo_abs" worktree add -b "$branch" "$location" 2>/dev/null \
          || git -C "$repo_abs" worktree add "$location" "$branch" 2>/dev/null \
          || die "git worktree add failed for branch $branch"
      fi
      ;;
    cwd)
      location="${cwd:-$PWD}"
      [[ -d "$location" ]] || die "dispatch --cwd not a directory: $location"
      ;;
    *) die "dispatch --isolation must be 'worktree' or 'cwd' (got: $iso)" ;;
  esac

  tmux new-session -d -s "$name" -c "$location" || die "failed to create session: $name"

  # Readiness marker for this session (sentinel echo, per DESIGN §11.2).
  local ready="<<<TMT_READY:$name>>>"
  reg_write "$name" "$type" "$opening" "$iso" "$location" "$branch" "$ready"

  # Launch the opening command / agent.
  [[ -n "$opening" ]] && _send_line "$name" "$opening"

  printf '%s✓ dispatched%s %s  type=%s iso=%s\n  location: %s%s\n' \
    "$c_grn" "$c_reset" "$name" "$type" "$iso" "$location" \
    "${branch:+$'\n'  branch: $branch}"
}

# Emit a digest a coding agent can read to summarize/decide input.
cmd_agent_scan() {
  have_tmux
  local filter='*' json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter) filter="$2"; shift 2 ;;
      --json)   json=1; shift ;;
      *) shift ;;
    esac
  done

  if [[ $json -eq 1 ]]; then
    need jq
    local first=1
    printf '['
    while IFS= read -r sess; do
      [[ -z "$sess" ]] && continue
      local line st rest cmd tail type task iso
      line=$(detect "$sess")
      st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}
      tail=$(tmux capture-pane -t "$sess" -p -S -20 2>/dev/null)
      type=$(reg_get "$sess" type); task=$(reg_get "$sess" task); iso=$(reg_get "$sess" isolation)
      [[ $first -eq 0 ]] && printf ','
      first=0
      jq -n --arg s "$sess" --arg st "$st" --arg c "$cmd" --arg t "$tail" \
            --arg ty "$type" --arg ta "$task" --arg is "$iso" \
        '{session:$s, state:$st, fg_process:$c, type:$ty, task:$ta, isolation:$is, pane_tail:$t}'
    done < <(list_sessions "$filter")
    printf ']\n'
  else
    while IFS= read -r sess; do
      [[ -z "$sess" ]] && continue
      local line st rest cmd
      line=$(detect "$sess")
      st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}
      printf '### session: %s\nstate: %s\nfg_process: %s\n--- pane tail ---\n' "$sess" "$st" "$cmd"
      tmux capture-pane -t "$sess" -p -S -20 2>/dev/null
      printf '\n\n'
    done < <(list_sessions "$filter")
  fi
}

# --- serve: live HTML dashboard -------------------------------------------
#
# Regenerates a static index.html from the same scan data agent-scan uses, then
# serves the directory with `python3 -m http.server`. The page carries a
# <meta http-equiv="refresh"> matching the poll interval, so a browser shows
# near-real-time state with zero client JS. Read-only: it never sends input.
#
# Bound to 127.0.0.1 only — panes can contain secrets, so we never expose them
# on the network.

# HTML-escape stdin (&, <, > only — enough for text nodes / <pre>).
_html_escape() { sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g'; }

# Map a state to a CSS class name (reused as color keys in the page's <style>).
_serve_state_class() {
  case "$1" in
    RUNNING) printf 'running' ;; WAITING) printf 'waiting' ;;
    STALE)   printf 'stale' ;;   IDLE)    printf 'idle' ;;
    *)       printf 'unknown' ;;
  esac
}

# Write one complete dashboard HTML document to stdout.
# Args: filter interval lines
_serve_render_html() {
  local filter="$1" interval="$2" lines="$3"
  local now; now=$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date)

  # Gather rows first so we can show a summary count in the header. detect()
  # mutates per-session hash state, so call it exactly once per session here.
  local -a rows_sess rows_state rows_cmd rows_task rows_pane
  local n=0
  local sess line st rest cmd task pane
  while IFS= read -r sess; do
    [[ -z "$sess" ]] && continue
    line=$(detect "$sess")
    st=${line%%$'\t'*}; rest=${line#*$'\t'}; cmd=${rest%%$'\t'*}
    task=$(reg_get "$sess" task)
    pane=$(tmux capture-pane -t "$sess" -p -S "-$lines" 2>/dev/null)
    rows_sess[n]="$sess"; rows_state[n]="$st"; rows_cmd[n]="$cmd"
    rows_task[n]="$task"; rows_pane[n]="$pane"
    n=$((n+1))
  done < <(list_sessions "$filter")

  # Per-state counts for the header badges.
  local c_running=0 c_waiting=0 c_stale=0 c_idle=0 i
  for ((i=0; i<n; i++)); do
    case "${rows_state[i]}" in
      RUNNING) c_running=$((c_running+1)) ;;
      WAITING) c_waiting=$((c_waiting+1)) ;;
      STALE)   c_stale=$((c_stale+1)) ;;
      IDLE)    c_idle=$((c_idle+1)) ;;
    esac
  done

  cat <<HTMLHEAD
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta http-equiv="refresh" content="$interval">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>tmt dashboard</title>
<style>
  :root { color-scheme: light dark; }
  * { box-sizing: border-box; }
  body { font: 14px/1.5 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
         margin: 0; padding: 1.2rem; background: #0b0f14; color: #d7dde3; }
  h1 { font-size: 1.1rem; margin: 0 0 .2rem; }
  .meta { color: #7d8794; font-size: .82rem; margin-bottom: 1rem; }
  .badges { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .badge { padding: .15rem .55rem; border-radius: 999px; font-size: .78rem;
           border: 1px solid #263040; }
  .card { border: 1px solid #263040; border-radius: 8px; margin-bottom: 1rem;
          overflow: hidden; background: #0f151d; }
  .card > header { display: flex; align-items: center; gap: .6rem;
                   padding: .55rem .8rem; background: #141c26; }
  .dot { width: .7rem; height: .7rem; border-radius: 50%; flex: 0 0 auto; }
  .name { font-weight: 700; }
  .fg { color: #7d8794; font-size: .8rem; margin-left: auto; }
  .task { color: #9aa4b0; font-size: .8rem; }
  .state-tag { font-size: .72rem; padding: .05rem .45rem; border-radius: 4px;
               border: 1px solid currentColor; }
  pre { margin: 0; padding: .7rem .8rem; overflow-x: auto; white-space: pre-wrap;
        word-break: break-word; max-height: 22rem; overflow-y: auto;
        font-size: .8rem; color: #c2cad3; }
  .running { color: #4ade80; } .waiting { color: #fbbf24; }
  .stale   { color: #f87171; } .idle    { color: #6b7480; }
  .unknown { color: #9aa4b0; }
  .dot.running { background:#4ade80; } .dot.waiting { background:#fbbf24; }
  .dot.stale   { background:#f87171; } .dot.idle    { background:#6b7480; }
  .dot.unknown { background:#9aa4b0; }
  .empty { color: #7d8794; padding: 2rem; text-align: center; }
</style>
</head>
<body>
<h1>tmt — live session dashboard</h1>
<div class="meta">filter <code>$filter</code> · refresh ${interval}s · updated $now · $n session(s)</div>
<div class="badges">
  <span class="badge running">▶ $c_running running</span>
  <span class="badge waiting">⏳ $c_waiting waiting</span>
  <span class="badge stale">■ $c_stale stale</span>
  <span class="badge idle">· $c_idle idle</span>
</div>
HTMLHEAD

  if [[ $n -eq 0 ]]; then
    printf '<div class="empty">no sessions match filter <code>%s</code></div>\n' "$filter"
  fi

  # WAITING and STALE first (they want attention), then RUNNING, then IDLE.
  local order pass
  for pass in WAITING STALE RUNNING IDLE OTHER; do
    for ((i=0; i<n; i++)); do
      order="${rows_state[i]}"
      case "$pass" in
        OTHER) [[ "$order" =~ ^(WAITING|STALE|RUNNING|IDLE)$ ]] && continue ;;
        *)     [[ "$order" != "$pass" ]] && continue ;;
      esac
      local klass; klass=$(_serve_state_class "${rows_state[i]}")
      local esc_sess esc_cmd esc_task esc_pane
      esc_sess=$(printf '%s' "${rows_sess[i]}" | _html_escape)
      esc_cmd=$(printf '%s'  "${rows_cmd[i]}"  | _html_escape)
      esc_task=$(printf '%s' "${rows_task[i]}" | _html_escape)
      esc_pane=$(printf '%s' "${rows_pane[i]}" | _html_escape)
      printf '<div class="card">\n'
      printf '  <header>\n'
      printf '    <span class="dot %s"></span>\n' "$klass"
      printf '    <span class="name">%s</span>\n' "$esc_sess"
      printf '    <span class="state-tag %s">%s</span>\n' "$klass" "${rows_state[i]}"
      [[ -n "$esc_task" ]] && printf '    <span class="task">%s</span>\n' "$esc_task"
      printf '    <span class="fg">%s</span>\n' "$esc_cmd"
      printf '  </header>\n'
      printf '  <pre>%s</pre>\n' "$esc_pane"
      printf '</div>\n'
    done
  done

  printf '</body>\n</html>\n'
}

cmd_serve() {
  have_tmux
  need python3
  local filter='*' interval=3 port=8787 lines=40
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter)   filter="$2"; shift 2 ;;
      --interval) interval="$2"; shift 2 ;;
      --port)     port="$2"; shift 2 ;;
      --lines)    lines="$2"; shift 2 ;;
      *) die "serve: unknown option: $1" ;;
    esac
  done
  [[ "$interval" =~ ^[0-9]+$ && "$interval" -ge 1 ]] || die "serve: --interval must be a positive integer"
  [[ "$port" =~ ^[0-9]+$ ]] || die "serve: --port must be a number"
  [[ "$lines" =~ ^[0-9]+$ ]] || die "serve: --lines must be a number"

  # Serve out of a private temp dir so the http.server can't expose anything
  # else. Cleaned up on exit.
  local webdir; webdir=$(mktemp -d "$STATE_DIR/serve.XXXXXX") || die "cannot create temp dir"

  # Background refresher: regenerate index.html every $interval seconds.
  ( while true; do
      _serve_render_html "$filter" "$interval" "$lines" > "$webdir/index.html.tmp" 2>/dev/null
      mv -f "$webdir/index.html.tmp" "$webdir/index.html"
      sleep "$interval"
    done ) &
  local refresher=$!

  printf '%s✓ dashboard%s http://127.0.0.1:%s/  (filter=%s refresh=%ss)\n' \
    "$c_grn" "$c_reset" "$port" "$filter" "$interval"
  printf '%sread-only; Ctrl-C to stop%s\n' "$c_dim" "$c_reset"

  # Start the server (bind localhost only) as a tracked child so we can kill it
  # on any exit path — not just interactive Ctrl-C, which would hit the whole
  # process group anyway.
  ( cd "$webdir" && exec python3 -m http.server "$port" --bind 127.0.0.1 ) 2>/dev/null &
  local server=$!

  # Clean up both children and the temp dir however we exit.
  trap 'kill "$refresher" "$server" 2>/dev/null; rm -rf "$webdir"' EXIT INT TERM

  # Block until the server exits (Ctrl-C, or the port dies).
  wait "$server"
}

# --- save / restore -------------------------------------------------------
#
# A snapshot is a tab-separated file, one line per pane:
#   session <TAB> window_index <TAB> window_name <TAB> pane_index <TAB>
#   window_layout <TAB> cwd <TAB> foreground_command
# Comment lines (#) carry metadata. This mirrors what tmux-resurrect stores:
# it recreates the session *layout* and re-runs the foreground command; it
# cannot revive process memory (nothing can, across a reboot).

# Return the foreground command line for a pane's tty (empty if just a shell).
_pane_fg_cmd() {
  local tty="${1#/dev/}"
  # stat with '+' = foreground process group; skip the login shell itself.
  ps -t "$tty" -o stat=,args= 2>/dev/null | awk '
    $1 ~ /\+/ {
      cmd=$0; sub(/^[[:space:]]*[^[:space:]]+[[:space:]]+/, "", cmd)   # drop stat col
      if (cmd ~ /^-?(bash|zsh|sh|fish|dash|tcsh|ksh)$/) next            # bare shell
      print cmd; exit
    }'
}

# Escape a field for our TSV (newlines/tabs would corrupt the format).
_tsv() { printf '%s' "$1" | tr '\n\t' '  '; }

cmd_save() {
  have_tmux
  local filter='*' name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter) filter="$2"; shift 2 ;;
      --name)   name="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  local stamp file
  stamp=$(date +%Y%m%d-%H%M%S)
  file="$SNAP_DIR/${name:-snapshot}-$stamp.tsv"

  {
    printf '# tmux-tasks snapshot v1\n'
    printf '# created %s  filter %s  host %s\n' "$(date -Iseconds 2>/dev/null || date)" "$filter" "$(hostname 2>/dev/null)"
    while IFS= read -r sess; do
      [[ -z "$sess" ]] && continue
      while IFS=$'\t' read -r win winname pane layout cwd tty; do
        local fg; fg=$(_pane_fg_cmd "$tty")
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
          "$(_tsv "$sess")" "$win" "$(_tsv "$winname")" "$pane" \
          "$(_tsv "$layout")" "$(_tsv "$cwd")" "$(_tsv "$fg")"
      done < <(tmux list-panes -s -t "$sess" \
                 -F $'#{window_index}\t#{window_name}\t#{pane_index}\t#{window_layout}\t#{pane_current_path}\t#{pane_tty}' 2>/dev/null)
    done < <(list_sessions "$filter")
  } > "$file"

  # keep a stable "latest" pointer and prune old snapshots
  ln -sf "$(basename "$file")" "$SNAP_DIR/latest.tsv"
  ls -1t "$SNAP_DIR"/*.tsv 2>/dev/null | grep -v '/latest.tsv$' | tail -n +$((SNAP_KEEP+1)) | xargs -r rm -f

  local n; n=$(grep -vc '^#' "$file")
  printf '%s✓ saved%s %s panes -> %s\n' "$c_grn" "$c_reset" "$n" "$file"
}

cmd_snapshots() {
  local f n created
  if ! ls "$SNAP_DIR"/*.tsv &>/dev/null; then
    printf '%sno snapshots yet (run: tmt save)%s\n' "$c_dim" "$c_reset"; return
  fi
  printf '%s%-40s %-8s %s%s\n' "$c_bold" "SNAPSHOT" "PANES" "CREATED" "$c_reset"
  for f in $(ls -1t "$SNAP_DIR"/*.tsv 2>/dev/null); do
    [[ "$(basename "$f")" == latest.tsv ]] && continue
    n=$(grep -vc '^#' "$f")
    created=$(sed -n 's/^# created \([^ ]*\).*/\1/p' "$f" | head -1)
    printf '%-40s %-8s %s\n' "$(basename "$f")" "$n" "$created"
  done
  [[ -L "$SNAP_DIR/latest.tsv" ]] && printf '%slatest -> %s%s\n' "$c_dim" "$(readlink "$SNAP_DIR/latest.tsv")" "$c_reset"
}

# Resolve a snapshot argument to a path: empty=latest, a name, or a full path.
_snap_path() {
  local arg="${1:-}"
  if [[ -z "$arg" ]]; then printf '%s' "$SNAP_DIR/latest.tsv"; return; fi
  [[ -f "$arg" ]] && { printf '%s' "$arg"; return; }
  [[ -f "$SNAP_DIR/$arg" ]] && { printf '%s' "$SNAP_DIR/$arg"; return; }
  [[ -f "$SNAP_DIR/$arg.tsv" ]] && { printf '%s' "$SNAP_DIR/$arg.tsv"; return; }
  return 1
}

cmd_restore() {
  need tmux
  local dry=0 run=0 snap=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run|-n) dry=1; shift ;;
      --run)        run=1; shift ;;   # also re-run captured commands
      *)            snap="$1"; shift ;;
    esac
  done
  local file
  file=$(_snap_path "$snap") || die "snapshot not found: ${snap:-latest} (see: tmt snapshots)"

  # Restore is session-level: one tmux session per task (matches how tmt is
  # used). We act on the first pane line seen per session; additional
  # panes/windows in the snapshot are informational only. Full multi-pane
  # layout revival is intentionally out of scope.
  local created=0 skipped=0
  local seen=" "
  while IFS=$'\t' read -r sess win winname pane layout cwd fg; do
    [[ "$sess" == \#* || -z "$sess" ]] && continue
    case "$seen" in *" $sess "*) continue ;; esac   # first line per session only
    seen+="$sess "

    if [[ $dry -eq 1 ]]; then
      printf '%swould restore%s %s  cwd=%s%s%s\n' \
        "$c_cyn" "$c_reset" "$sess" "$cwd" "${fg:+  cmd=}" "$fg"
      continue
    fi

    if tmux has-session -t "$sess" 2>/dev/null; then
      skipped=$((skipped+1)); continue
    fi
    tmux new-session -d -s "$sess" -c "$cwd" 2>/dev/null && created=$((created+1))
    [[ -n "$fg" && $run -eq 1 ]] && _send_line "$sess" "$fg"
  done < "$file"

  if [[ $dry -eq 1 ]]; then
    printf '%s(dry run — nothing changed)%s\n' "$c_dim" "$c_reset"
  else
    printf '%s✓ restored%s %s session(s), skipped %s existing  (from %s)\n' \
      "$c_grn" "$c_reset" "$created" "$skipped" "$(basename "$file")"
    [[ $run -eq 0 ]] && printf '%stip: re-run captured commands with --run%s\n' "$c_dim" "$c_reset"
  fi
}

cmd_watch() {
  have_tmux
  local filter='*' interval=3
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --filter)   filter="$2"; shift 2 ;;
      --interval) interval="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  while true; do
    printf '\033[H\033[2J'  # home + clear
    printf '%stmt%s  filter=%s  %s(refresh %ss)%s\n\n' "$c_bold$c_cyn" "$c_reset" "$filter" "$c_dim" "$interval" "$c_reset"
    render_table "$filter"
    printf '\n%s[#]attach  [s]end-input  [c]apture  [k]ey  [r]efresh  [q]uit%s\n> ' "$c_dim" "$c_reset"

    local input=''
    read -r -t "$interval" input || { continue; }   # timeout → auto-refresh
    [[ -z "$input" ]] && continue

    case "$input" in
      q|quit) printf 'bye\n'; break ;;
      r)      continue ;;
      s)      _interactive_send ;;
      c)      _interactive_capture ;;
      k)      _interactive_key ;;
      [0-9]*) _interactive_attach "$input" ;;
      *) ;;
    esac
  done
}

_pick() {  # echo session name for an index, or empty
  local idx="$1"
  [[ "$idx" =~ ^[0-9]+$ ]] || return 1
  [[ -n "${SESS[idx]:-}" ]] && printf '%s' "${SESS[idx]}"
}

_interactive_attach() {
  local sess; sess=$(_pick "$1") || { printf 'no such #\n'; sleep 1; return; }
  [[ -z "$sess" ]] && { printf 'no such #\n'; sleep 1; return; }
  printf 'attaching to %s (detach with ctrl-b d)...\n' "$sess"; sleep 0.5
  tmux attach -t "$sess"
}

_interactive_send() {
  printf 'session #: '; local n; read -r n
  local sess; sess=$(_pick "$n") || { printf 'bad #\n'; sleep 1; return; }
  [[ -z "$sess" ]] && { printf 'bad #\n'; sleep 1; return; }
  printf '%slast line of %s:%s\n' "$c_dim" "$sess" "$c_reset"
  tmux capture-pane -t "$sess" -p 2>/dev/null | grep -v '^[[:space:]]*$' | tail -n 1
  printf 'text to send (Enter appended): '; local text; read -r text
  printf 'send %s"%s"%s to %s? [y/N] ' "$c_yel" "$text" "$c_reset" "$sess"
  local ok; read -r ok
  [[ "$ok" == y || "$ok" == Y ]] && _send_line "$sess" "$text" && { printf 'sent.\n'; sleep 0.6; }
}

_interactive_key() {
  printf 'session #: '; local n; read -r n
  local sess; sess=$(_pick "$n") || { printf 'bad #\n'; sleep 1; return; }
  [[ -z "$sess" ]] && { printf 'bad #\n'; sleep 1; return; }
  printf 'tmux key(s) to send (e.g. Enter, C-c, y Enter): '; local keys; read -r keys
  # shellcheck disable=SC2086
  tmux send-keys -t "$sess" $keys && { printf 'sent.\n'; sleep 0.6; }
}

_interactive_capture() {
  printf 'session #: '; local n; read -r n
  local sess; sess=$(_pick "$n") || { printf 'bad #\n'; sleep 1; return; }
  [[ -z "$sess" ]] && { printf 'bad #\n'; sleep 1; return; }
  printf '\033[2J\033[H'
  cmd_status "$sess"
  printf '\n%s[enter to return]%s' "$c_dim" "$c_reset"; read -r _
}

# Print the leading comment header (lines 3.. up to the first non-comment line),
# stripping the leading "# ". Robust to the header changing length.
usage() {
  awk 'NR<3{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
}

main() {
  local sub="${1:-watch}"; shift || true
  case "$sub" in
    watch)       cmd_watch "$@" ;;
    ls|list)     cmd_ls "$@" ;;
    status)      cmd_status "$@" ;;
    capture)     cmd_capture "$@" ;;
    send)        cmd_send "$@" ;;
    key)         cmd_key "$@" ;;
    new)         cmd_new "$@" ;;
    dispatch)    cmd_dispatch "$@" ;;
    registry)    cmd_registry "$@" ;;
    save)        cmd_save "$@" ;;
    restore)     cmd_restore "$@" ;;
    snapshots)   cmd_snapshots "$@" ;;
    agent-scan)  cmd_agent_scan "$@" ;;
    serve)       cmd_serve "$@" ;;
    attach)      cmd_attach "$@" ;;
    version|--version|-V) printf 'tmt (tmux-tasks) %s\n' "$TMT_VERSION" ;;
    -h|--help|help) usage ;;
    *) die "unknown subcommand: $sub (try: tmt --help)" ;;
  esac
}

main "$@"
